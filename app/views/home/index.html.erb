<div class="sidebar">
  <button id="new-chat" onclick="newConversation()">+ Novo chat</button>
  <h2>Histórico</h2>
  <div class="chat-history">
    <% @conversations.each do |conv| %>
      <div class="chat-item">
        <a href="/?conversation_id=<%= conv.id %>"><%= conv.title %></a>
      </div>
    <% end %>
  </div>
</div>

<div class="main">
  <div class="chat-box" id="chat-box">
    <% @messages.each do |msg| %>
      <div class="message <%= msg.role %>">
        <%= msg.content %>
      </div>
    <% end %>
  </div>

  <input type="hidden" id="conversation-id" value="<%= @current_conversation&.id %>">

  <div class="input-area">
    <input type="text" id="input" placeholder="Digite sua mensagem...">
    <button id="send">Enviar</button>
  </div>
</div>